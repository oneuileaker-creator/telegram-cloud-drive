# App
APP_NAME=FTMS
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=your-super-secret-key-change-this
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ftms
SYNC_DATABASE_URL=postgresql://postgres:password@localhost:5432/ftms

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Telegram
TELEGRAM_API_ID=your-api-id
TELEGRAM_API_HASH=your-api-hash

# Chunk Settings
CHUNK_SIZE_MB=500
MAX_FILE_SIZE_GB=10
